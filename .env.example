# ============================================================
# Tadabbur — Environment Variables Template
# Copy this to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# ============================================================

# Django
SECRET_KEY=change-this-to-a-long-random-string-at-least-50-chars
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=thetadabbur.org,www.thetadabbur.org,localhost

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://thetadabbur.org,https://www.thetadabbur.org

# MongoDB
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB_NAME=tadabbur
MONGO_USERNAME=tadabbur_user
MONGO_PASSWORD=change-this-strong-mongo-password

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (self-hosted S3)
# For Docker local dev: MINIO_ENDPOINT=http://minio:9000, MINIO_PUBLIC_URL=http://localhost:9000
# For external MinIO:   MINIO_ENDPOINT=https://s3.yourdomain.com, MINIO_PUBLIC_URL=https://s3.yourdomain.com
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=change-this-minio-access-key
MINIO_SECRET_KEY=change-this-minio-secret-key
MINIO_BUCKET_NAME=tadabbur-media
MINIO_ASSETS_BUCKET=tadabbur-assets

# YouTube (for the Videos feature)
# Get from: https://console.cloud.google.com/ → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-v3-key-here
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (AI lesson translation) — OPTIONAL fallback.
# Preferred: set this from the admin panel (Admin → Languages). This env var is
# only used when the admin-stored key is empty. Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend (Vite env vars — prefixed VITE_ to be exposed to browser)
VITE_API_BASE_URL=/api/v1
